      "axes.linewidth": 0.75,
      "axes.spines.top": false,
      "axes.spines.right": false,
      "xtick.major.width": 0.75,
      "ytick.major.width": 0.75,
      "pdf.fonttype": 42,
      "ps.fonttype": 42
    }
  }
}
