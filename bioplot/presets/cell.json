{
  "font": {
    "family": "Arial",
    "title_size": 9.0,
    "axis_label_size": 8.0,
    "tick_label_size": 7.0,
    "legend_size": 8.0,
    "annotation_size": 7.0,
    "bold_title": false
  },
  "figure": {
    "width_mm": 85.0,
    "height_mm": 85.0,
    "dpi": 300,
    "tight_layout": true
  },
  "marker": {
    "size": 12.0,
    "alpha": 0.75
  },
  "extras": {
