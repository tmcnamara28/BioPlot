<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow reading files anywhere the user selects via file dialog -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Allow writing to Downloads folder for exports -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>

    <!-- Hardened runtime: allow JIT (needed by some scipy/numpy routines) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow unsigned executable memory (numpy/scipy BLAS) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Disable library validation to allow bundled dylibs -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Network access for future cloud features -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
